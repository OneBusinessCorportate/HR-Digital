# ─── Supabase ───────────────────────────────────────────────────────────────
# Public project URL and publishable (anon) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service-role key — SERVER ONLY. Never expose to the browser. Used for
# privileged server-side operations (e.g. spreadsheet import, admin seeding).
# Leave empty to disable those features.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Recruitment business rules ──────────────────────────────────────────────
# Default test pass threshold (percent). Can be overridden per-environment or in
# the recruitment_settings DB table (DB value wins).
TEST_PASS_THRESHOLD=70

# Business timezone used for all date-boundary metric calculations.
NEXT_PUBLIC_APP_TIMEZONE=Asia/Yerevan
